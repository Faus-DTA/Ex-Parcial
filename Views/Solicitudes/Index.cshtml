@model PlataformaCreditos.Models.SolicitudesFilterViewModel

@{
    ViewData["Title"] = "Mis Solicitudes";
}

<h1>Mis Solicitudes</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="mb-3 text-end">
    <a asp-action="Create" class="btn btn-success">Nueva Solicitud</a>
</div>

<div class="card mb-4">
    <div class="card-header">Filtros</div>
    <div class="card-body">
        <form method="get">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Estado</label>
                    <select asp-for="Estado" asp-items="Html.GetEnumSelectList<PlataformaCreditos.Models.EstadoSolicitud>()" class="form-select">
                        <option value="">Todos</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Monto Min.</label>
                    <input asp-for="MontoMin" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="MontoMin" class="text-danger"></span>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Monto Max.</label>
                    <input asp-for="MontoMax" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="MontoMax" class="text-danger"></span>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Fecha Inicio</label>
                    <input asp-for="FechaInicio" class="form-control" type="date" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Fecha Fin</label>
                    <input asp-for="FechaFin" class="form-control" type="date" />
                    <span asp-validation-for="FechaFin" class="text-danger"></span>
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">Filtrar</button>
                </div>
            </div>
        </form>
    </div>
</div>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>ID</th>
            <th>Fecha Solicitud</th>
            <th>Monto Solicitado</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Solicitudes.Any())
        {
            <tr>
                <td colspan="5" class="text-center">No se encontraron solicitudes.</td>
            </tr>
        }
        @foreach (var item in Model.Solicitudes)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.FechaSolicitud.ToString("dd/MM/yyyy HH:mm")</td>
                <td>@item.MontoSolicitado.ToString("C")</td>
                <td>
                    @if(item.Estado == PlataformaCreditos.Models.EstadoSolicitud.Aprobado) { <span class="badge bg-success">Aprobado</span> }
                    else if(item.Estado == PlataformaCreditos.Models.EstadoSolicitud.Rechazado) { <span class="badge bg-danger">Rechazado</span> }
                    else { <span class="badge bg-warning text-dark">Pendiente</span> }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Detalle</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
