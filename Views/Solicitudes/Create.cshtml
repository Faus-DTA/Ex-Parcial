@model PlataformaCreditos.Models.CreateSolicitudViewModel

@{
    ViewData["Title"] = "Nueva Solicitud";
}

<h1>Nueva Solicitud de Crédito</h1>

<div class="row">
    <div class="col-md-6">
        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
        {
            <div class="alert alert-danger">
                <strong>No se pudo procesar tu solicitud:</strong>
                <div asp-validation-summary="All" class="text-danger mb-0"></div>
            </div>
        }

        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label asp-for="MontoSolicitado" class="form-label">Monto a Solicitar</label>
                <div class="input-group">
                    <span class="input-group-text">$</span>
                    <input asp-for="MontoSolicitado" class="form-control" type="number" step="0.01" />
                </div>
                <span asp-validation-for="MontoSolicitado" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <button type="submit" class="btn btn-primary">Enviar Solicitud</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
