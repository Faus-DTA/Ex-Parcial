@model IEnumerable<PlataformaCreditos.Models.SolicitudCredito>

@{
    ViewData["Title"] = "Panel de Analista";
}

<h1>Panel de Analista - Solicitudes Pendientes</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<table class="table table-striped table-hover mt-4">
    <thead>
        <tr>
            <th>ID</th>
            <th>Fecha Solicitud</th>
            <th>Cliente (ID)</th>
            <th>Ingresos Mensuales</th>
            <th>Monto Solicitado</th>
            <th>Límite Aprobación (5x)</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="7" class="text-center">No hay solicitudes pendientes en este momento.</td>
            </tr>
        }
        @foreach (var item in Model)
        {
            var limite = item.Cliente.IngresosMensuales * 5;
            var puedeAprobarse = item.MontoSolicitado <= limite;
            <tr>
                <td>@item.Id</td>
                <td>@item.FechaSolicitud.ToString("dd/MM/yyyy HH:mm")</td>
                <td>@item.Cliente.UsuarioId</td>
                <td>@item.Cliente.IngresosMensuales.ToString("C")</td>
                <td>@item.MontoSolicitado.ToString("C")</td>
                <td class="@(puedeAprobarse ? "text-success" : "text-danger fw-bold")">@limite.ToString("C")</td>
                <td>
                    <div class="d-flex gap-2">
                        @if (puedeAprobarse)
                        {
                            <form asp-action="Aprobar" asp-route-id="@item.Id" method="post">
                                <button type="submit" class="btn btn-sm btn-success">Aprobar</button>
                            </form>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-secondary" disabled title="Monto excede 5x ingresos">Aprobar</button>
                        }
                        
                        <a asp-action="Rechazar" asp-route-id="@item.Id" class="btn btn-sm btn-danger text-white">Rechazar</a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
